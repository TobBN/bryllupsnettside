# Kopier denne filen til .env.local for lokal utvikling mot testdatabasen
# cp .env.local.example .env.local
#
# VIKTIG: Bruk alltid testprosjektet lokalt og i Vercel Preview – aldri produksjonslegitimasjon!

# ── Supabase TESTPROSJEKT ──────────────────────────────────────────────────────
# Lag et gratis testprosjekt på https://app.supabase.com og fyll inn verdiene
NEXT_PUBLIC_SUPABASE_URL=https://<test-project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<test-service-role-key>

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=test-passord-lokalt
COOKIE_SECRET=test-cookie-secret-lokalt-32tegn-min

# ── Produksjon (ALDRI legg disse her) ─────────────────────────────────────────
# Produksjonsverdiene settes kun i Vercel Dashboard under Environment = Production
